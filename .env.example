# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# ── Символ и таймфрейм ────────────────────────────────────────────────────
SYMBOL=QQQ.US
TIMEFRAME_MINUTES=5
POLL_SECONDS=10
CHART_BARS=240

# ── TraderNet ─────────────────────────────────────────────────────────────
TRADERNET_API_URL=https://tradernet.ru/api/
TRADERNET_QUOTES_URL=https://tradernet.ru/securities/export
TRADERNET_SID=           # опционально — SID сессии для авторизации
TRADERNET_TIMEOUT_SECONDS=20

# ── История ───────────────────────────────────────────────────────────────
HISTORY_LOOKBACK_DAYS=7
DISPLAY_TZ=America/New_York
CACHE_DIR=               # по умолчанию ~/qqq_trading_bot_cache

# ── Стратегия ─────────────────────────────────────────────────────────────
STRATEGY_ID=1            # 1 = BB+EMA+RSI+Опционы, 2 = MACD+VWAP+RSI+ST
COOLDOWN_SECONDS=300

# ── Параметры стратегии #1 ────────────────────────────────────────────────
BB_PERIOD=20
BB_STD=2.0
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
RSI_BUY=35
RSI_SELL=65
RSI_BUY_BOUNCE=40
RSI_SELL_BOUNCE=60
NEAR_BB_TOL=0.0025
BOUNCE_LOOKBACK=3

# ── Параметры стратегии #2 ────────────────────────────────────────────────
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
VWAP_PRICE_MODE=typical
SUPERTREND_PERIOD=10
SUPERTREND_MULT=3.0
ATR_PERIOD=14
ATR_STOP_MULT=3.0
VOL_MA_PERIOD=20
EMA_TREND_PERIOD=200

# ── Опционные сигналы (стратегии #1 и #2) ────────────────────────────────
OPTION_SIGNALS_ENABLED=1       # 1 = включить, 0 = отключить
OPTION_MIN_DTE=1               # минимум дней до экспирации (0 = разрешить 0DTE, 1 = со следующего дня)
OPTION_STRIKE_STEP=1.0         # шаг страйка в долларах (QQQ стандарт = $1)
OPTION_TARGET_DELTA=0.375      # целевая дельта для выбора страйка (0.35–0.40)
OPTION_MAX_DTE=4               # максимальный срок до экспирации (дней); в пятницу не улетит на 2 недели
OPTION_MAX_EXPIRY_TRIES=8      # сколько дней-кандидатов перебрать в поисках торгуемой экспирации
OPTION_RISK_FREE_RATE=0.05     # безрисковая ставка для Black-Scholes
OPTION_UNDERLYING=QQQ.US       # тикер в TraderNet для опционной цепочки
OPTION_REQUIRE_VALIDATION=0    # 1 = не открывать опцион без подтверждения котировки TraderNet
# Временные окна торговли опционами (RTH 9:30–16:00 ET). На сам QQQ сигналы идут и в расширенные часы.
OPTION_OPEN_BLACKOUT_MIN=10    # не открывать опцион первые N минут после открытия (волатильность)
OPTION_CLOSE_BLACKOUT_MIN=15   # не открывать/закрывать за N минут до закрытия
OPTION_FORCE_CLOSE_MIN=15      # принудительно закрывать за N минут до закрытия (не держать ночь)


# ── Консенсус трёх источников (#1, #2, ML) ───────────────────────────────
CONSENSUS_ENABLED=1            # 1 = включить ансамбль и consensus-сообщения
CONSENSUS_WINDOW_BARS=12       # окно согласия (баров); голос активен N баров
CONSENSUS_WEIGHT_S1=1.0        # вес стратегии #1
CONSENSUS_WEIGHT_S2=1.0        # вес стратегии #2
CONSENSUS_WEIGHT_ML=1.0        # вес ML-блока
CONSENSUS_ML_MIN_EDGE=0.05     # порог |long_prob-short_prob| для голоса ML
CONSENSUS_CONFLICT_THRESHOLD=1.0  # порог score для пометки конфликта

# ── ML (advisory-режим для консенсуса) ───────────────────────────────────
ML_ENABLED=1                   # 1 = ML участвует в консенсусе (advisory)
ML_MODE=advisory               # advisory = только голос, ничего не блокирует
ML_MODEL_DIR=qqq_bot/ml/models # папка с обученной моделью
ML_MIN_BARS=240                # минимум баров истории для инференса

# ══════════════════════════════════════════════════════════════════════════
# МУЛЬТИАККАУНТ: список счетов через запятую. Для каждого — свои переменные
# с префиксом (FFA_*, TFOS_*). Размер позиции независимый (% от своего счёта).
EXEC_ACCOUNTS=ffa

# ── Счёт FFA (можно использовать старые EXEC_*/TRADERNET_* как fallback) ──
# FFA_ENABLED=1
# FFA_LABEL=FFA
# FFA_PUBLIC_KEY=
# FFA_PRIVATE_KEY=
# FFA_POSITION_PCT=5
# FFA_MAX_CONTRACTS=1

# ── Счёт TFOS (второй счёт, другая юрисдикция, свои ключи) ──
# Чтобы включить: EXEC_ACCOUNTS=ffa,tfos и заполни переменные ниже
# TFOS_ENABLED=1
# TFOS_LABEL=TFOS
# TFOS_PUBLIC_KEY=
# TFOS_PRIVATE_KEY=
# TFOS_POSITION_PCT=3
# TFOS_MAX_POSITION_PCT=5
# TFOS_MAX_CONTRACTS=1
# TFOS_MAX_NOTIONAL=500
# TFOS_HOLD_OVERNIGHT_MIN_DTE=99
# TFOS_BLOCK_NEW_IF_DTE_LTE=0
# TFOS_CONFIRM_TIMEOUT_SEC=300

# БОЕВОЕ ИСПОЛНЕНИЕ СДЕЛОК — ВНИМАНИЕ: РЕАЛЬНЫЕ ДЕНЬГИ
# ══════════════════════════════════════════════════════════════════════════
# По умолчанию ВЫКЛЮЧЕНО. Включай только когда полностью протестировал.
EXEC_ENABLED=0                 # 0 = выключено (только сигналы), 1 = исполнение включено
EXEC_MODE=semi_auto            # semi_auto = подтверждение кнопкой | auto | off

# API-ключи TraderNet с правом ТОРГОВЛИ (НЕ SID!). Приватный ключ = доступ к деньгам.
# ХРАНИ БЕЗОПАСНО. Никогда не коммить .env в git (он в .gitignore).
TRADERNET_PUBLIC_KEY=
TRADERNET_PRIVATE_KEY=

# Sizing — размер позиции в % от счёта
EXEC_POSITION_PCT=5.0          # % от размера счёта на одну сделку
EXEC_MAX_POSITION_PCT=10.0     # жёсткий потолок %
EXEC_MAX_CONTRACTS=50          # абсолютный потолок контрактов

# Предохранители
EXEC_MAX_ORDERS_PER_DAY=20     # лимит ордеров в день
EXEC_MAX_NOTIONAL=50000        # макс. номинал одной сделки, $

# 0DTE / overnight защита (после урока с маржой $1M!)
EXEC_HOLD_OVERNIGHT_MIN_DTE=99 # держать ночь только если DTE >= этого. 99 = НЕ держать никогда
EXEC_BLOCK_NEW_IF_DTE_LTE=0    # не открывать позицию если DTE <= этого (0DTE-защита)
EXEC_REQUIRE_RECONCILE=1       # сверять позицию с брокером перед действием
EXEC_CONFIRM_TIMEOUT_SEC=300   # тайм-аут подтверждения ордера кнопкой, сек (5 мин)
