# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=-1003542254060

# Instrument
SYMBOL=QQQ.US
TIMEFRAME_MINUTES=5

# Polling / chart
POLL_SECONDS=10
CHART_BARS=240
CACHE_DIR=.cache

# TraderNet endpoints
TRADERNET_API_URL=https://tradernet.com/api/
TRADERNET_QUOTES_URL=https://tradernet.com/securities/export
TRADERNET_SID=
TRADERNET_TIMEOUT_SECONDS=20
# History bootstrap (lookback window in calendar days)
HISTORY_LOOKBACK_DAYS=7

# Indicators
BB_PERIOD=20
BB_STD=2.0

EMA_FAST=9
EMA_SLOW=21

RSI_PERIOD=14

# Signal thresholds (your logic)
RSI_BUY=40
RSI_SELL=60
RSI_BUY_BOUNCE=45
RSI_SELL_BOUNCE=55

# “Near band” tolerance (fraction of price)
NEAR_BB_TOL=0.0025

# Bounce detection
BOUNCE_LOOKBACK=12

# Optional: timezone for labeling
DISPLAY_TZ=America/New_York
# No cooldown by design for the updated STR#2/options logic
COOLDOWN_SECONDS=0


# --- Strategy #2 updated logic ---
STRATEGY_ID=2
STR2_REGULAR_ONLY=true
STR2_ALLOW_SHORT_ENTRIES=true
STR2_BREAKOUT_LOOKBACK=12
STR2_PULLBACK_LOOKBACK=5
STR2_MIN_VOLUME_RATIO_BREAKOUT=1.05
STR2_MIN_ATR_PCT_BREAKOUT=0.0012
STR2_LONG_RSI_MIN=52
STR2_SHORT_RSI_MAX=48
STR2_BREAKOUT_RSI_MIN=55
STR2_BREAKOUT_SHORT_RSI_MAX=45
STR2_MAX_EXTENSION_ATR_PULLBACK=1.2

# --- Outcome ML filter ---
ML_ENABLED=true
ML_OUTCOME_MODEL_DIR=qqq_bot/ml/models
ML_LONG_05ATR_MIN=0.55
ML_LONG_10ATR_MIN=0.40
ML_SHORT_05ATR_MIN=0.55
ML_SHORT_10ATR_MIN=0.40

# --- QQQ options block ---
OPTIONS_ENABLED=true
OPTIONS_ENABLE_0DTE=true
OPTIONS_REQUIRE_STRONG_MOVE_FOR_0DTE=true
OPTIONS_REQUIRE_ML_FOR_0DTE=true
OPTIONS_ALLOW_OPEN_PUT=true
OPTIONS_TARGET_DELTA=0.38
OPTIONS_IV_ASSUMPTION=0.25
OPTIONS_LOG_QUOTES=true
OPTIONS_LOGS_DIR=logs
# Optional HTTP endpoint returning option bid/ask/last/iv/greeks as JSON by ?ticker=...
OPTION_QUOTE_URL=
